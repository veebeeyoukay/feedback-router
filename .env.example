# Environment configuration example
FEEDBACK_ROUTER_DEBUG=False
FEEDBACK_ROUTER_LOG_LEVEL=INFO
FEEDBACK_ROUTER_ENVIRONMENT=development

# Database
FEEDBACK_ROUTER_DATABASE_URL=postgresql://user:password@localhost:5432/feedback_router
FEEDBACK_ROUTER_DATABASE_POOL_SIZE=10
FEEDBACK_ROUTER_DATABASE_MAX_OVERFLOW=20
FEEDBACK_ROUTER_DATABASE_ECHO=False

# Redis
FEEDBACK_ROUTER_REDIS_HOST=localhost
FEEDBACK_ROUTER_REDIS_PORT=6379
FEEDBACK_ROUTER_REDIS_DB=0
FEEDBACK_ROUTER_REDIS_PASSWORD=

# Slack
FEEDBACK_ROUTER_SLACK_BOT_TOKEN=xoxb-your-token-here
FEEDBACK_ROUTER_SLACK_SIGNING_SECRET=your-signing-secret
FEEDBACK_ROUTER_SLACK_APP_TOKEN=xapp-your-token-here
FEEDBACK_ROUTER_SLACK_MONITORED_CHANNELS=feedback,feature-requests,bugs,complaints,customer-feedback,support

# Webhooks
FEEDBACK_ROUTER_WEBHOOK_SECRET=your-webhook-secret
FEEDBACK_ROUTER_WEBHOOK_RATE_LIMIT=100
FEEDBACK_ROUTER_WEBHOOK_RATE_LIMIT_WINDOW=60
