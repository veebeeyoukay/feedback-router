# Feedback Router: Environment Variables Template
# Copy this file to .env and fill in your values
# REQUIRED variables must be set. OPTIONAL variables have sensible defaults.

# ============================================================================
# API & APPLICATION CONFIGURATION
# ============================================================================

# REQUIRED: API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Environment: development|staging|production
API_ENV=development

# Enable debug mode (logging, stack traces, etc.)
DEBUG=false

# Secret key for JWT tokens and session management
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-at-least-64-hex-characters

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================

# REQUIRED: PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://feedback_user:secure_password@localhost:5432/feedback_router
DATABASE_URL=postgresql://feedback_user:password@localhost:5432/feedback_router

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Log SQL queries (useful for debugging)
DATABASE_ECHO=false

# Auto-run migrations on startup
AUTO_MIGRATE=true

# ============================================================================
# CACHE & QUEUE CONFIGURATION (Redis)
# ============================================================================

# REQUIRED: Redis connection string
# Format: redis://[:password]@host:port/database
# Example: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================================================
# SLACK INTEGRATION
# ============================================================================

# OPTIONAL: Slack bot token for message posting and event handling
# Get from: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
# Starts with: xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# OPTIONAL: Slack signing secret for webhook verification
# Get from: https://api.slack.com/apps → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-here

# OPTIONAL: Slack workspace ID (for workspace-specific API calls)
SLACK_WORKSPACE_ID=T_YOUR_WORKSPACE_ID

# OPTIONAL: Slack channel ID for feedback (if you want to post to specific channel)
SLACK_FEEDBACK_CHANNEL=C_YOUR_CHANNEL_ID

# Enable/disable Slack integration
ENABLE_SLACK_INTEGRATION=true

# ============================================================================
# AI/LLM CONFIGURATION (Anthropic)
# ============================================================================

# REQUIRED: Anthropic API key for Claude
# Get from: https://console.anthropic.com/account/keys
# Starts with: sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Model to use for classification and generation
# Options: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, etc.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Temperature for model (0.0-1.0, lower = deterministic, higher = creative)
ANTHROPIC_TEMPERATURE=0.7

# Max tokens for classification responses
ANTHROPIC_MAX_TOKENS=2000

# ============================================================================
# GOOGLE DRIVE INTEGRATION (OPTIONAL)
# ============================================================================

# Path to Google Service Account credentials JSON file
# For integration with Google Drive company docs
# Leave empty to disable Google Drive integration
GOOGLE_DRIVE_CREDENTIALS_JSON=/path/to/google-credentials.json

# Folder ID in Google Drive containing company documentation
# Format: Long string ID from Google Drive URL
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here

# Refresh interval for company docs cache (in hours)
GOOGLE_DRIVE_REFRESH_INTERVAL=24

# ============================================================================
# EMAIL CONFIGURATION (OPTIONAL - for Wave 2 email channel)
# ============================================================================

# SMTP server hostname
SMTP_HOST=smtp.itjen.ai

# SMTP port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username
SMTP_USER=noreply@itjen.ai

# SMTP password
SMTP_PASSWORD=your-smtp-password

# From address for outgoing emails
SMTP_FROM_EMAIL=feedback@itjen.ai

# Enable TLS
SMTP_TLS=true

# ============================================================================
# CELERY CONFIGURATION (Task Queue)
# ============================================================================

# Celery broker URL (must be same as REDIS_URL typically)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Task time limit (seconds) - tasks will be killed after this time
CELERY_TASK_TIME_LIMIT=600

# Worker concurrency (number of parallel tasks per worker)
CELERY_WORKER_CONCURRENCY=4

# ============================================================================
# SECURITY & JWT
# ============================================================================

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# Rate limiting: requests per minute (unauthenticated)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Rate limiting: requests per minute (authenticated)
RATE_LIMIT_AUTHENTICATED_REQUESTS_PER_MINUTE=1000

# Enable CORS (set to your frontend domain in production)
CORS_ORIGINS=["http://localhost:3000", "https://itjen.ai"]

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable website widget
ENABLE_WEBSITE_WIDGET=true

# Enable Slack integration
ENABLE_SLACK_INTEGRATION=true

# Enable auto-respond (vs. always human review)
ENABLE_AUTO_RESPOND=true

# Enable email channel (Wave 2)
ENABLE_EMAIL_CHANNEL=false

# Enable support ticket channel (Wave 2)
ENABLE_TICKET_CHANNEL=false

# Enable chat history (Future)
ENABLE_CHAT_HISTORY=false

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: DEBUG|INFO|WARNING|ERROR
LOG_LEVEL=INFO

# Log format: json (for production) or text (for development)
LOG_FORMAT=json

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/ → Projects → [Your Project] → Settings → Client Keys
SENTRY_DSN=

# Datadog API key for metrics (optional)
DATADOG_API_KEY=

# New Relic license key (optional)
NEW_RELIC_LICENSE_KEY=

# Enable structured logging
STRUCTURED_LOGGING=true

# ============================================================================
# HEALTH CHECKS & MONITORING
# ============================================================================

# Enable health check endpoint
HEALTHCHECK_ENABLED=true

# Health check interval (seconds)
HEALTHCHECK_INTERVAL_SECONDS=30

# Dead letter queue enabled
DLQ_ENABLED=true

# DLQ max retries before permanent fail
DLQ_MAX_RETRIES=5

# ============================================================================
# WEBSITE WIDGET CONFIGURATION
# ============================================================================

# Website widget enabled
WIDGET_ENABLED=true

# Widget API endpoint base URL
WIDGET_API_URL=https://api.itjen.ai

# Widget CDN URL (where widget.js and widget.css are hosted)
WIDGET_CDN_URL=https://cdn.itjen.ai

# ============================================================================
# CLASSIFICATION & ROUTING
# ============================================================================

# High confidence threshold (above which we auto-route)
CLASSIFICATION_HIGH_CONFIDENCE_THRESHOLD=0.85

# Medium confidence threshold (between 0.6 and this value)
CLASSIFICATION_MEDIUM_CONFIDENCE_THRESHOLD=0.60

# Classification cache TTL (seconds) - cache results for identical content
CLASSIFICATION_CACHE_TTL=604800  # 7 days

# Routing rules cache enabled
ROUTING_RULES_CACHE=true

# Deduplication window (minutes) - consider feedback duplicate if within this window
DEDUP_WINDOW_MINUTES=30

# Dedup similarity threshold (0.0-1.0, higher = stricter)
DEDUP_SIMILARITY_THRESHOLD=0.90

# ============================================================================
# RESPONSE GENERATION
# ============================================================================

# Enable FAQ matching for auto-responses
ENABLE_FAQ_MATCHING=true

# FAQ confidence threshold (above which we use FAQ response)
FAQ_CONFIDENCE_THRESHOLD=0.80

# Enable sentiment-aware responses
ENABLE_SENTIMENT_RESPONSES=true

# ============================================================================
# DEVELOPMENT ONLY (do not use in production)
# ============================================================================

# Allow insecure HTTP connections (development only)
ALLOW_INSECURE_HTTP=false

# Test data: load sample feedback on startup
LOAD_SAMPLE_DATA=false

# Mock external APIs (useful for offline development)
MOCK_APIS=false

# ============================================================================
# NOTES
# ============================================================================

# Required variables (no default):
# - DATABASE_URL
# - ANTHROPIC_API_KEY
# - SECRET_KEY
# - SLACK_BOT_TOKEN (if ENABLE_SLACK_INTEGRATION=true)
# - SLACK_SIGNING_SECRET (if ENABLE_SLACK_INTEGRATION=true)

# Optional variables (have sensible defaults):
# - All others have defaults specified in src/config.py

# For development:
# 1. Copy this file to .env
# 2. Fill in only the REQUIRED variables
# 3. Defaults will be used for optional variables
# 4. For local testing, use localhost URLs and test API keys

# For production:
# 1. Use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# 2. Never commit .env files with real secrets
# 3. Use environment variables from CI/CD deployment
# 4. Enable structured logging and monitoring
# 5. Set API_ENV=production
# 6. Set DEBUG=false
